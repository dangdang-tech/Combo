# 本地直接运行模板。复制为 .env.local 后填写空值，不要提交真实凭据。
DATABASE_URL=postgres://combo:combo@localhost:5432/combo
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_URL=redis://localhost:6379/0
REDIS_HOT_URL=redis://localhost:6380/0
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=combo

# authoring API 的第一方邮件验证码配置。本地模拟服务默认监听 4010 端口。
PUBLIC_APP_ORIGIN=http://localhost:5173
RESEND_API_BASE_URL=http://127.0.0.1:4010
RESEND_API_KEY=
RESEND_FROM_EMAIL=
OTP_HMAC_SECRET=

# LLM 配置可以留空；相关能力会降级，但认证主链路仍可运行。
LLM_PROVIDER=anthropic
LLM_BASE_URL=https://api.anthropic.com
LLM_MODEL=claude-sonnet-4-20250514
LLM_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# 可观测性配置可以留空。设置后应用通过 OTLP HTTP 导出。
OTEL_SERVICE_NAME=cb-authoring-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local
