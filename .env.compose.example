# 生产口径 Compose 环境变量示例。复制为 .env 后必须填写所有必填项。
# `${VAR:?}` 会拒绝未设置或空值，scripts/start.sh 还会拒绝已知弱默认值。
# 不要把真实密钥提交到 Git；测试邮件凭据由 scripts/integration/resend-auth-e2e.sh 临时生成。

# ───────────────────────── 进程通用 ─────────────────────────
NODE_ENV=production
LOG_LEVEL=info
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# ───────────────────────── PostgreSQL ─────────────────────────
# 所有者账号只供 PostgreSQL 初始化和迁移容器使用。密码通过独立字段传递，可以包含 /、#、? 等 URI 保留字符。
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# 三份 URL-safe 独立密码由迁移 runner 设置；业务容器不会收到所有者凭据。
POSTGRES_API_PASSWORD=
POSTGRES_WORKER_PASSWORD=
POSTGRES_RUNTIME_PASSWORD=

# ───────────────────────── Redis 双实例 ─────────────────────────
REDIS_QUEUE_URL=redis://redis_queue:6379/0
REDIS_HOT_URL=redis://redis_hot:6379/0

# ───────────────────────── ObjectStore / MinIO ─────────────────────────
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
# 浏览器预签直传使用的公网地址。生产应填写 HTTPS 的 S3 或 CDN 入口。
S3_PUBLIC_ENDPOINT=

# ───────────────────────── 第一方邮箱认证 ─────────────────────────
# 必须是浏览器实际访问站点的精确 HTTPS origin，不带路径、查询或结尾之外的内容。
PUBLIC_APP_ORIGIN=
# 生产只允许官方 Resend HTTPS 基址。只有 dev-test 覆盖层会改成容器内测试替身。
RESEND_API_BASE_URL=https://api.resend.com
RESEND_API_KEY=
# 必须是 Resend 已验证域名允许使用的发件地址。
RESEND_FROM_EMAIL=
# 至少三十二字符的高熵随机值，只由 authoring API 消费。轮换会使五分钟内活动验证码失效。
OTP_HMAC_SECRET=

# ───────────────────────── LLM Gateway ─────────────────────────
# LLM 配置为空时服务按 degraded 运行，不影响认证、已有会话或 readiness。
LLM_PROVIDER=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=
RUNTIME_LLM_PROVIDER=
RUNTIME_LLM_MODEL=

# 服务器 Docker 数据目录覆盖。普通本机安装可保持默认。
DOCKER_CONTAINERS_DIR=/var/lib/docker/containers
