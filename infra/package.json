{
  "name": "@cb/infra",
  "version": "0.0.0",
  "private": true,
  "description": "第一方邮箱认证、业务服务、数据组件和同源入口的 Compose 与 Kubernetes 编排。",
  "type": "module",
  "scripts": {
    "compose:config": "docker compose --env-file ../.env -f docker-compose.yml config --quiet",
    "compose:up": "docker compose --env-file ../.env -f docker-compose.yml up -d",
    "compose:down": "docker compose --env-file ../.env -f docker-compose.yml down",
    "typecheck": "echo 'no ts in infra' && exit 0",
    "test": "node --test resend-mock/server.test.mjs"
  }
}
