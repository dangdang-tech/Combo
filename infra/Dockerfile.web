# Web 静态构建 + nginx（O-01）。本期只写不构建（无 Docker）。
FROM node:24-slim AS build
WORKDIR /app
ARG VITE_DEPLOY_ENV=production
ARG VITE_BUILD_SHA=unknown
ARG VITE_REVIEW_SOURCE=manual
ENV VITE_DEPLOY_ENV=$VITE_DEPLOY_ENV \
    VITE_BUILD_SHA=$VITE_BUILD_SHA \
    VITE_REVIEW_SOURCE=$VITE_REVIEW_SOURCE
RUN corepack enable && corepack prepare pnpm@11.0.9 --activate
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* tsconfig.base.json tsconfig.json ./
COPY packages ./packages
COPY apps ./apps
RUN pnpm install --frozen-lockfile=false
# 同镜像同时构建创作者中心（web）与试用端（runtime-web，base=/try/）静态产物。
RUN pnpm -F @cb/shared build && pnpm -F @cb/web build && pnpm -F @cb/runtime-web build

FROM nginx:alpine AS runtime
COPY --from=build /app/apps/web/dist /usr/share/nginx/html
# 试用端静态挂在 /try/（nginx.conf 里 location ^~ /try/ alias 到此）。
COPY --from=build /app/apps/runtime-web/dist /usr/share/nginx/try
# nginx 官方入口会对 templates/*.template 执行 envsubst。默认值覆盖 Compose；K3s overlay
# 注入 CoreDNS 与 Service FQDN，同一镜像无需因部署环境重新改配置。
ENV NGINX_RESOLVER=127.0.0.11 API_UPSTREAM_HOST=api RUNTIME_UPSTREAM_HOST=runtime
COPY infra/nginx.conf /etc/nginx/templates/default.conf.template
EXPOSE 80
